FLASK_ENV=development
FLASK_DEBUG=true
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000

SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-different-long-random-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nail_disease_ai
DB_USER=root
DB_PASSWORD=
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/nail_disease_ai

MAX_UPLOAD_MB=10
MIN_IMAGE_WIDTH=224
MIN_IMAGE_HEIGHT=224
MIN_BLUR_SCORE=30
UPLOAD_FOLDER=uploads

MODEL_DIR=model_artifacts
UNET_MODEL_PATH=model_artifacts/unet.keras
CLASSIFIER_MODEL_PATH=model_artifacts/classifier.keras
GRADCAM_LAYER_NAME=
MODEL_VERSION=unconfigured
ALLOW_DEMO_INFERENCE=false
